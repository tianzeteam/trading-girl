# 交易媛 — Environment Configuration
# Copy to .env and fill in your keys

# Bitget Demo Trading API credentials
# Create at: https://www.bitget.com → Switch to Demo Mode → API Key Management
BITGET_PAPER_API_KEY=bg_your_demo_api_key_here
BITGET_PAPER_SECRET_KEY=your_demo_secret_key_here
BITGET_PAPER_PASSPHRASE=your_demo_passphrase_here

# Optional: Telegram notifications
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
